# Backend: "mock" (fixtures, no creds — default) or "live" (self-hosted GitLab).
RCA_BACKEND=mock

# --- Live GitLab (RCA_BACKEND=live) ---
# Self-hosted GitLab base URL (no trailing /api/v4 — added automatically).
GITLAB_URL=https://gitlab.example.com
# Personal Access Token with READ scope only (read_api / read_repository).
GITLAB_TOKEN=

# --- Jira ---
# Preferred: direct Jira Cloud REST with an API token (self-contained, no MCP).
# When all three are set, the app fetches tickets by key via JiraClient.
JIRA_URL=https://your-site.atlassian.net
JIRA_EMAIL=
JIRA_TOKEN=
# Alternative: the Atlassian remote MCP server (OAuth) — used by the agent loop
# only when that MCP is inherited/authenticated for the SDK; no token needed there.

# --- Agent loop (--agent path) ---
# Anthropic API key for the Claude Agent SDK.
ANTHROPIC_API_KEY=
# Model the agent loop uses.
RCA_MODEL=claude-opus-4-8

# Lines of context fetched around a suspect line during verification.
RCA_CONTEXT_LINES=12

# Where published indexes (graph maps + summaries) live. Defaults to fixtures/
# (mock). Point it at a real index store so live indexes stay separate from
# test fixtures. The real repos indexed so far live here:
RCA_INDEX_DIR=index
